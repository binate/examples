// Command run is the non-interactive minbasic host: it constructs the I/O
// delegate and runs a BASIC program. (M0 skeleton: drives the banner; M1 reads a
// .bas file from the command line and runs it.)
package "main"

import "pkg/basic"
import "pkg/host"

// main constructs the console I/O delegate and runs the BASIC program.
func main() {
	basic.Run(host.NewConsole())
}
