// Command run is the non-interactive minbasic host: it runs a BASIC program.
// (M0 skeleton: drives the banner; M1 reads a .bas file from the command line
// and runs it.)
//
// TEMP: once the injected-io.ConsoleOut path compiles (see
// explorations/claude-todo.md), this constructs the host delegate and injects
// it: `basic.Run(host.NewConsole())`. For now the engine emits via a static host
// call, so main just drives it.
package "main"

import "pkg/basic"

func main() {
	basic.Run()
}
