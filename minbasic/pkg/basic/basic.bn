package "pkg/basic"

import "pkg/basic/io"

// Run drives the interpreter, routing all output through the injected sink. M0
// skeleton: emit a banner so the cmd -> basic -> io -> host wiring is exercised
// before any interpreter logic exists.
func Run(out @io.ConsoleOut) {
	out.Write("minbasic - ECMA-55 Minimal BASIC (skeleton)\n")
}
