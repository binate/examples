package "pkg/basic"

import "pkg/basic/io"
import "pkg/buf"

// captureOut is a test io.ConsoleOut that accumulates everything written, so a
// test can assert what a runtime emitted (program output and diagnostics).
type captureOut struct {
	b buf.CharBuf
}

func (c @captureOut) Write(s *[]readonly char) int {
	c.b = c.b.WriteStr(s)
	return len(s)
}

impl @captureOut : io.ConsoleOut

// text returns everything written to c so far as a fresh slice.
func (c @captureOut) text() @[]char {
	return c.b.Freeze()
}

// nullIn is a test io.ConsoleIn that always reports end-of-input; evaluator and
// non-INPUT executor tests never read a reply.
type nullIn struct {
	dummy int
}

func (n @nullIn) ReadLine() io.InLine {
	var res io.InLine
	res.Text = make_slice(char, 0)
	res.Eof = true
	return res
}

impl @nullIn : io.ConsoleIn

// newNullIn returns a null INPUT source.
func newNullIn() @io.ConsoleIn {
	var n @nullIn = make(nullIn)
	n.dummy = 0
	var cin @io.ConsoleIn = n
	return cin
}

// contains reports whether hay holds needle as a substring (a naive scan, used to
// assert that a diagnostic appears in captured output).
func contains(hay @[]char, needle *[]readonly char) bool {
	var n int = len(needle)
	if n == 0 {
		return true
	}
	for i := 0; i + n <= len(hay); i++ {
		var match bool = true
		for j := 0; j < n; j++ {
			if hay[i + j] != needle[j] {
				match = false
				break
			}
		}
		if match {
			return true
		}
	}
	return false
}

// buildRT builds a runtime that writes to cap (used for both program output and
// diagnostics) and reads from a null INPUT source, over a one-line dummy program
// so the executing-line lookups in nonfatal reporting are valid.
func buildRT(cap @captureOut) @runtime {
	var line @Line = make(Line)
	line.Num = 10
	line.Stmt = simpleStmt(ST_REM)
	var prog @[]@Line = make_slice(@Line, 1)
	prog[0] = line
	var lm @lineMap = buildLineMap(prog)
	var data @[]@datum = make_slice(@datum, 0)
	var defs @defStore = make(defStore)
	var out @io.ConsoleOut = cap
	var inp @io.ConsoleIn = newNullIn()
	return newRuntime(out, out, inp, prog, lm, data, 0, defs)
}

// newEvalRT is the harness for evaluator tests, which inspect returned values and
// the fatal flag rather than emitted text.
func newEvalRT() @runtime {
	var cap @captureOut = make(captureOut)
	cap.b = buf.New()
	return buildRT(cap)
}

// runWithIn parses and runs the full program src reading INPUT replies from inp,
// returning the captured output (program PRINT output plus any diagnostics) and
// the resulting variable store.
func runWithIn(src @[]char, inp @io.ConsoleIn) (@[]char, @env) {
	var cap @captureOut = make(captureOut)
	cap.b = buf.New()
	var out @io.ConsoleOut = cap
	var prog @[]@Line
	var perr @[]char
	var ok bool
	prog, perr, ok = parseProgram(src)
	if !ok {
		emitDiag(out, perr)
		return cap.text(), newEnv(0)
	}
	var e @env = runProgramInto(prog, out, out, inp)
	return cap.text(), e
}

// runProg runs src with no INPUT replies available — the harness for executor
// tests that do not read INPUT.
func runProg(src @[]char) (@[]char, @env) {
	return runWithIn(src, newNullIn())
}

// scriptIn is a test io.ConsoleIn that replays a fixed list of reply lines, then
// reports end-of-input.
type scriptIn struct {
	lines @[]@[]char
	pos   int
}

func (s @scriptIn) ReadLine() io.InLine {
	var res io.InLine
	if s.pos >= len(s.lines) {
		res.Text = make_slice(char, 0)
		res.Eof = true
		return res
	}
	res.Text = s.lines[s.pos]
	res.Eof = false
	s.pos = s.pos + 1
	return res
}

impl @scriptIn : io.ConsoleIn

// runProgInput runs src with the given INPUT reply lines (consumed in order; a
// further read past them reports end-of-input).
func runProgInput(src @[]char, replies @[]@[]char) (@[]char, @env) {
	var s @scriptIn = make(scriptIn)
	s.lines = replies
	s.pos = 0
	var inp @io.ConsoleIn = s
	return runWithIn(src, inp)
}

// noopWrite is a ReplIO channel that discards framing output (a non-capturing
// function value, like cmd/basic's frameOut).
func noopWrite(s *[]readonly char) int {
	return len(s)
}

// newSession builds a REPL session whose framing (banner/prompts/LIST/diagnostics)
// is discarded and whose BASIC program output is captured, with no INPUT replies.
// Returns the session and the program-output capture.
func newSession() (@ReplSession, @captureOut) {
	var rio ReplIO
	rio.WriteOut = noopWrite
	rio.WriteErr = noopWrite
	var cap @captureOut = make(captureOut)
	cap.b = buf.New()
	var out @io.ConsoleOut = cap
	var inp @io.ConsoleIn = newNullIn()
	var sess @ReplSession
	var errs @[]ReplError
	sess, errs = NewSession(rio, out, inp)
	return sess, cap
}

// u8 copies a char slice into a uint8 slice (the same bytes) for Step's raw input
// view.
func u8(line @[]char) @[]uint8 {
	var out @[]uint8 = make_slice(uint8, len(line))
	for i := 0; i < len(line); i++ {
		out[i] = cast(uint8, line[i])
	}
	return out
}

// feed runs one input line through the session.
func feed(sess @ReplSession, line @[]char) {
	sess.Step(u8(line), false)
}
