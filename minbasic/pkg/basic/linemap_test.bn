package "pkg/basic"

import "pkg/builtins/testing"

// TestLineMapLookup checks the line-number -> program-index map and its
// out-of-range handling.
func TestLineMapLookup() testing.TestResult {
	var prog @[]@Line = make_slice(@Line, 3)
	prog[0] = make(Line)
	prog[0].Num = 10
	prog[1] = make(Line)
	prog[1].Num = 20
	prog[2] = make(Line)
	prog[2].Num = 100
	var lm @lineMap = buildLineMap(prog)
	if lm.lookup(10) != 0 {
		return "lookup(10) should be index 0"
	}
	if lm.lookup(20) != 1 {
		return "lookup(20) should be index 1"
	}
	if lm.lookup(100) != 2 {
		return "lookup(100) should be index 2"
	}
	if lm.lookup(50) != -1 {
		return "lookup of an absent line should be -1"
	}
	if lm.lookup(0) != -1 {
		return "lookup(0) is out of range -> -1"
	}
	if lm.lookup(10000) != -1 {
		return "lookup(10000) is out of range -> -1"
	}
	return ""
}
