package "pkg/basic"

import "pkg/builtins/testing"

func TestArrayIndex() testing.TestResult {
	if arrayIndex("A") != 0 {
		return "arrayIndex(A) should be 0"
	}
	if arrayIndex("M") != 12 {
		return "arrayIndex(M) should be 12"
	}
	if arrayIndex("Z") != 25 {
		return "arrayIndex(Z) should be 25"
	}
	return ""
}

// TestExtent pins base..upper inclusive: base 0 gives upper+1 subscripts, base 1
// gives upper.
func TestExtent() testing.TestResult {
	var a0 @arrayStore = newArrayStore(0)
	if a0.extent(10) != 11 {
		return "base 0: extent(10) should be 11"
	}
	if a0.extent(0) != 1 {
		return "base 0: extent(0) should be 1"
	}
	var a1 @arrayStore = newArrayStore(1)
	if a1.extent(10) != 10 {
		return "base 1: extent(10) should be 10"
	}
	if a1.extent(1) != 1 {
		return "base 1: extent(1) should be 1"
	}
	return ""
}

func TestDimDeclareAllocates1D() testing.TestResult {
	var a @arrayStore = newArrayStore(0)
	var i int = arrayIndex("A")
	a.dimDeclare(i, 1, 5, 0)
	if a.dims[i] != 1 {
		return "dims should be 1"
	}
	if !a.explicit[i] {
		return "a DIM-declared array should be explicit"
	}
	if len(a.cells[i]) != 6 {
		return "1-D base 0 upper 5 should allocate 6 cells"
	}
	return ""
}

func TestDimDeclareAllocates2D() testing.TestResult {
	var a @arrayStore = newArrayStore(0)
	var i int = arrayIndex("B")
	a.dimDeclare(i, 2, 2, 3)
	if a.dims[i] != 2 {
		return "dims should be 2"
	}
	// extent(2) = 3 rows, extent(3) = 4 cols -> 12 cells.
	if len(a.cells[i]) != 12 {
		return "2-D should allocate rows*cols = 12 cells"
	}
	return ""
}

func TestFlatIndex1D() testing.TestResult {
	var a @arrayStore = newArrayStore(0)
	var i int = arrayIndex("A")
	a.dimDeclare(i, 1, 5, 0)
	var off int
	var ok bool
	off, ok = a.flatIndex(i, 0, 0)
	if !ok || off != 0 {
		return "flatIndex(0) should be (0, true)"
	}
	off, ok = a.flatIndex(i, 5, 0)
	if !ok || off != 5 {
		return "flatIndex(5) should be (5, true)"
	}
	off, ok = a.flatIndex(i, 6, 0)
	if ok {
		return "flatIndex(6) should be out of range"
	}
	off, ok = a.flatIndex(i, -1, 0)
	if ok {
		return "flatIndex(-1) should be out of range"
	}
	return ""
}

// TestFlatIndex2D pins the row-major offset row*rowLen + col, rowLen = extent of
// the second dimension.
func TestFlatIndex2D() testing.TestResult {
	var a @arrayStore = newArrayStore(0)
	var i int = arrayIndex("B")
	a.dimDeclare(i, 2, 2, 3)
	var off int
	var ok bool
	off, ok = a.flatIndex(i, 0, 0)
	if !ok || off != 0 {
		return "flatIndex(0,0) should be (0, true)"
	}
	off, ok = a.flatIndex(i, 1, 2)
	if !ok || off != 6 {
		return "flatIndex(1,2) should be 1*4 + 2 = 6"
	}
	off, ok = a.flatIndex(i, 2, 3)
	if !ok || off != 11 {
		return "flatIndex(2,3) should be 11 (the last cell)"
	}
	off, ok = a.flatIndex(i, 2, 4)
	if ok {
		return "flatIndex(2,4): column out of range"
	}
	off, ok = a.flatIndex(i, 3, 0)
	if ok {
		return "flatIndex(3,0): row out of range"
	}
	return ""
}

// TestEnsureImplicit checks an undimensioned reference fixes the array at
// DEFAULT_BOUND, and a later reference does not re-dimension it.
func TestEnsureImplicit() testing.TestResult {
	var a @arrayStore = newArrayStore(0)
	var i int = arrayIndex("C")
	a.ensureImplicit(i, 1)
	if a.dims[i] != 1 {
		return "ensureImplicit should set dims to 1"
	}
	if a.upper1[i] != DEFAULT_BOUND {
		return "implicit upper bound should be DEFAULT_BOUND"
	}
	if a.explicit[i] {
		return "an implicitly-dimensioned array should not be explicit"
	}
	if len(a.cells[i]) != 11 {
		return "implicit 1-D base 0 should allocate 11 cells"
	}
	a.ensureImplicit(i, 2)
	if a.dims[i] != 1 {
		return "ensureImplicit must not re-dimension an established array"
	}
	return ""
}

// TestBase1FlatIndex checks OPTION BASE 1 shifts the valid subscript range to
// 1..upper and offsets from there.
func TestBase1FlatIndex() testing.TestResult {
	var a @arrayStore = newArrayStore(1)
	var i int = arrayIndex("A")
	a.dimDeclare(i, 1, 3, 0)
	var off int
	var ok bool
	off, ok = a.flatIndex(i, 1, 0)
	if !ok || off != 0 {
		return "base 1: flatIndex(1) should be (0, true)"
	}
	off, ok = a.flatIndex(i, 3, 0)
	if !ok || off != 2 {
		return "base 1: flatIndex(3) should be (2, true)"
	}
	off, ok = a.flatIndex(i, 0, 0)
	if ok {
		return "base 1: flatIndex(0) is below base"
	}
	off, ok = a.flatIndex(i, 4, 0)
	if ok {
		return "base 1: flatIndex(4) is above upper"
	}
	return ""
}
