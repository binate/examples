package "pkg/basic"

import "pkg/basic/io"

// ZONE_WIDTH is the width of a print zone in character positions (ECMA-55's
// implementation-defined value; we use the standard reference 15).
const ZONE_WIDTH int = 15

// NUM_ZONES is the number of print zones per line (the standard reference 5).
const NUM_ZONES int = 5

// MARGIN is the line width: NUM_ZONES * ZONE_WIDTH = 75 character positions.
const MARGIN int = 75

// MAX_STR_LEN is the ECMA-55 limit on a string datum assigned to a string
// variable (clause 11.5): assigning a longer string is a fatal error.
const MAX_STR_LEN int = 18

// runtime is the per-RUN execution context. env is the variable store; out the
// program-output sink; err the diagnostic sink (fatal diagnostics AND nonfatal-
// exception reports, kept off the program-output stream so a host can route them
// apart — cmd/run merges both to stdout); inp the INPUT reply source (consulted
// by execInput, never for PRINT); col the 0-based column the next character
// would occupy on the
// current line (for PRINT zone spacing). prog is the line-ordered program;
// lineMap resolves a line number to its index in prog (-1 if absent); pc is the
// program counter (an index into prog); fors is the stack of open FOR loops;
// gosubs is the GOSUB return stack. data is the program's global DATA sequence
// (collected at load) and dataPtr is the conceptual READ pointer into it (the
// index of the next datum). fatal/fatalMsg carry a fatal exception raised
// mid-expression (a not-yet-supported function or operator); they
// cannot be returned through the float64-typed evaluators, so the value is
// parked here and the step loop reports it after the statement. defs is the
// program's user-defined-function table (built at load), consulted when a
// reference FN<letter> is evaluated. rnd is the RND pseudo-random generator's
// xorshift64 state, seeded from a fixed constant per run so RND is reproducible.
type runtime struct {
	env      @env
	out      @io.ConsoleOut
	err      @io.ConsoleOut
	inp      @io.ConsoleIn
	col      int
	prog     @[]@Line
	lineMap  @lineMap
	pc       int
	fors     @forStack
	gosubs   @gosubStack
	data     @[]@datum
	dataPtr  int
	fatal    bool
	fatalMsg @[]char
	defs     @defStore
	rnd      uint64
}

// newRuntime builds a runtime over a fresh variable store writing program output
// to out and diagnostics to err, reading INPUT replies from inp, with the program
// prog, its precomputed line-number map, its global DATA sequence, and its
// user-defined-function table defs. base is the OPTION BASE array lower bound.
// The program counter starts at the first line; the FOR and GOSUB stacks start
// empty; the data pointer starts at the first datum; no array is dimensioned yet.
func newRuntime(out @io.ConsoleOut, err @io.ConsoleOut, inp @io.ConsoleIn, prog @[]@Line,
	lm @lineMap, data @[]@datum, base int, defs @defStore) @runtime {
	var r @runtime = make(runtime)
	r.env = newEnv(base)
	r.out = out
	r.err = err
	r.inp = inp
	r.col = 0
	r.prog = prog
	r.lineMap = lm
	r.pc = 0
	r.fors = newForStack()
	r.gosubs = newGosubStack()
	r.data = data
	r.dataPtr = 0
	r.fatal = false
	r.defs = defs
	r.rnd = RND_SEED
	return r
}

// setFatal records the first fatal exception raised during expression
// evaluation (later calls are no-ops so the original diagnostic survives). The
// step loop checks r.fatal after each statement and reports r.fatalMsg.
func (r @runtime) setFatal(msg @[]char) {
	if !r.fatal {
		r.fatal = true
		r.fatalMsg = msg
	}
}

// reportNonfatal reports a recovered (nonfatal) ECMA-55 exception (clause 3.5
// requires nonfatal exceptions to be reported even though execution continues),
// tagged with the executing line, through the diagnostic sink. Unlike setFatal it
// does not stop execution and does not touch the print column — the diagnostic is
// not part of the program's output layout.
func (r @runtime) reportNonfatal(msg @[]char) {
	emitDiag(r.err, lineDiag(r.prog[r.pc].Num, msg))
}

// emit writes s through the sink and advances the tracked print column. A
// newline resets the column to the start of the line.
func (r @runtime) emit(s @[]char) {
	r.out.Write(s)
	for i := 0; i < len(s); i++ {
		if s[i] == '\n' {
			r.col = 0
		} else {
			r.col = r.col + 1
		}
	}
}

// evalNum evaluates a numeric expression to its float64 value. Expression nodes
// are dispatched by Kind with an if/else-if chain (the codebase idiom).
func (r @runtime) evalNum(e @Expr) float64 {
	if e.Kind == EX_NUM {
		// A numeric-constant literal whose value is infinite can only have come
		// from an overflowing constant (the lexer never scans "inf"); ECMA-55
		// clause 8.5 makes that a nonfatal exception reported at evaluation, with
		// the constant recovered to signed machine infinity (already its value).
		if isInfinite(absf(e.Num)) {
			r.reportNonfatal(buf.CopyStr("numeric constant overflow"))
		}
		return e.Num
	} else if e.Kind == EX_VAR {
		return r.env.getNum(e.Name)
	} else if e.Kind == EX_UNARY {
		var v float64 = r.evalNum(e.X)
		if e.Op == TOK_MINUS {
			return -v
		}
		return v
	} else if e.Kind == EX_BINARY {
		return r.evalBinary(e)
	} else if e.Kind == EX_CALL {
		return r.evalCall(e)
	} else if e.Kind == EX_AINDEX {
		return r.evalArrayRef(e)
	} else if e.Kind == EX_FNCALL {
		return r.evalFnCall(e)
	}
	// EX_STR / EX_SVAR cannot appear in a numeric context (the parser keeps
	// numeric and string expressions apart); treat as 0.
	return 0.0
}

// evalBinary evaluates a binary arithmetic expression. For the `^` operator an
// integer exponent is computed exactly by repeated multiplication (powf); a
// non-integer exponent is a^b = exp(b*ln a) via math.Pow, except that a negative
// base with a non-integer exponent is the ECMA-55 fatal exception (clause 8 — the
// result is not real).
func (r @runtime) evalBinary(e @Expr) float64 {
	var a float64 = r.evalNum(e.X)
	var b float64 = r.evalNum(e.Y)
	if e.Op == TOK_PLUS {
		return a + b
	} else if e.Op == TOK_MINUS {
		return a - b
	} else if e.Op == TOK_STAR {
		return a * b
	} else if e.Op == TOK_SLASH {
		return a / b
	}
	if !integralExponent(b) {
		if a < 0.0 {
			r.setFatal(buf.CopyStr("negative number raised to a non-integer power"))
			return 0.0
		}
		return math.Pow(a, b)
	}
	return powf(a, b)
}

// integralExponent reports whether the `^` exponent b is an integer value (so
// the power can be computed exactly by repeated multiplication). 0^0 is defined
// as 1 by ECMA-55, and b == 0 is integral, so it takes the exact path too.
func integralExponent(b float64) bool {
	if isNaN(b) || isInfinite(absf(b)) {
		return false
	}
	return floorf(b) == b
}

// evalStr evaluates a string expression to its characters. ECMA-55 string
// expressions are only a string variable or a string constant.
func (r @runtime) evalStr(e @Expr) @[]char {
	if e.Kind == EX_SVAR {
		return r.env.getStr(e.Name)
	}
	return e.Str
}

// RND_SEED is the fixed initial state of the RND pseudo-random generator. ECMA-55
// makes RND reproducible without RANDOMIZE, so every run seeds from this constant
// and replays the same sequence. It is an arbitrary nonzero xorshift64 seed; the
// resulting sequence is minbasic's own (ECMA-55 leaves the RND sequence
// implementation-defined, so it matches no other implementation's RND).
const RND_SEED uint64 = 88172645463325252

// nextRnd advances the runtime's xorshift64 PRNG state and returns the next
// value, uniformly distributed in [0, 1). The top 53 bits of the 64-bit state
// form a double's mantissa; those bits never set the sign bit, so the
// uint64 -> float64 conversion is exact and positive.
func (r @runtime) nextRnd() float64 {
	var x uint64 = r.rnd
	x = x ^ (x << 13)
	x = x ^ (x >> 7)
	x = x ^ (x << 17)
	r.rnd = x
	return cast(float64, x >> 11) / 9007199254740992.0
}
