package "pkg/basic"

import "pkg/basic/io"

// STEP_NEXT .. STEP_ERROR are the outcomes of executing one statement (see
// runtime.step). STEP_NEXT falls through to the following line; STEP_JUMP means
// the statement set the program counter itself; STEP_END terminates the run;
// STEP_ERROR signals a fatal runtime error (with the message set out-of-band).
const (
	STEP_NEXT int = iota
	STEP_JUMP
	STEP_END
	STEP_ERROR
)

// runProgram executes a parsed program for the non-interactive runner: it builds
// a fresh variable store, runs the program (reading any INPUT replies from inp),
// and discards the final state. All load validation and execution is delegated
// to runProgramInto; the resulting env (which would let an interactive caller
// inspect variables afterward) is not needed here, so it is dropped.
func runProgram(prog @[]@Line, out @io.ConsoleOut, err @io.ConsoleOut, inp @io.ConsoleIn) {
	_ = runProgramInto(prog, out, err, inp)
}

// runProgramInto executes a parsed program with a jumping program counter and
// returns the resulting variable store, so an interactive caller (the REPL's RUN
// command) can inspect variables after the program ends. It builds the
// line-number map, validates every GOTO/IF target up front, then drives
// execution from the lowest-numbered line. The program counter advances by one
// line normally and is set directly by control statements (GOTO/IF/FOR/NEXT).
// INPUT replies are read through inp. Execution stops at END/STOP, a fatal
// runtime error (reported as a diagnostic line through err), or end-of-input
// while an INPUT awaits a reply (a clean stop). On a LOAD-time error (a bad jump
// target, a duplicate OPTION/DEF, a re-DIM) it reports the diagnostic and returns
// a fresh empty env, since no program state was established.
func runProgramInto(prog @[]@Line, out @io.ConsoleOut, err @io.ConsoleOut, inp @io.ConsoleIn) @env {
	var lm @lineMap = buildLineMap(prog)
	var badLine int
	var badTarget int
	if !checkTargets(prog, lm, &badLine, &badTarget) {
		emitDiag(err, lineDiag(badLine, noSuchLine(badTarget)))
		return newEnv(0)
	}
	var optIdx int
	var base int
	var optMsg @[]char
	if !checkOption(prog, &optIdx, &base, &optMsg) {
		emitDiag(err, optMsg)
		return newEnv(0)
	}
	var defs @defStore
	var defMsg @[]char
	var defOk bool
	defs, defMsg, defOk = collectDefs(prog)
	if !defOk {
		emitDiag(err, defMsg)
		return newEnv(base)
	}
	if !checkDefs(prog, defs, &defMsg) {
		emitDiag(err, defMsg)
		return newEnv(base)
	}
	var data @[]@datum = collectData(prog)
	var r @runtime = newRuntime(out, err, inp, prog, lm, data, base, defs)
	var dimMsg @[]char
	if !applyDims(prog, r.env, &dimMsg) {
		emitDiag(err, dimMsg)
		return r.env
	}
	// errMsg is declared ONCE here, not per-iteration inside the loop, to avoid a
	// current native-backend defect: a default-initialized managed local declared
	// in a loop body leaks ~native stack each iteration and overflows it after
	// ~130k iterations (tracked in explorations/claude-todo.md), which crashes the
	// compiled interpreter on long-running programs. Reusing one slot is safe —
	// *errMsg is read only in the STEP_ERROR branch, immediately after the r.step
	// that sets it. Move this back inside the loop once the backend defect is fixed
	// (see examples/TODO.md).
	var errMsg @[]char
	for r.pc < len(prog) {
		var status int = r.step(&errMsg)
		if status == STEP_ERROR {
			emitDiag(err, lineDiag(prog[r.pc].Num, errMsg))
			return r.env
		} else if status == STEP_END {
			return r.env
		} else if status == STEP_NEXT {
			r.pc = r.pc + 1
		}
		// STEP_JUMP: r.pc was set by the statement; leave it as-is.
	}
	return r.env
}

// checkTargets verifies at load time that every control-statement target line
// exists: the single target of GOTO/IF/GOSUB and every listed target of an
// ON…GOTO. On the first dangling reference it sets *badLine to the referencing
// line's number and *badTarget to the missing target, then returns false. This
// surfaces a broken jump as a clear diagnostic before any output is produced.
func checkTargets(prog @[]@Line, lm @lineMap, badLine *int, badTarget *int) bool {
	for i := 0; i < len(prog); i++ {
		var s @Stmt = prog[i].Stmt
		if !stmtTargetsExist(s, lm, badTarget) {
			*badLine = prog[i].Num
			return false
		}
	}
	return true
}

// stmtTargetsExist reports whether every line-number a control statement names
// exists in lm. On the first missing one it sets *badTarget and returns false;
// statements with no line-number target trivially pass.
func stmtTargetsExist(s @Stmt, lm @lineMap, badTarget *int) bool {
	if s.Kind == ST_GOTO || s.Kind == ST_IF || s.Kind == ST_GOSUB {
		if lm.lookup(s.Target) < 0 {
			*badTarget = s.Target
			return false
		}
	} else if s.Kind == ST_ON {
		for j := 0; j < len(s.Targets); j++ {
			if lm.lookup(s.Targets[j]) < 0 {
				*badTarget = s.Targets[j]
				return false
			}
		}
	}
	return true
}
