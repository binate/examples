 9.99999E-31    9.99999E-16    9.99999E-16    1.24972E-7     OK 
 1.23456E-20    1.11111E-10    1.11111E-10    .000468189     OK 
 .0000654321    .00808901      .00808901      .000393464     OK 
 .5             .707107        .707107        .000154491     OK 
 1              1              1              0              OK  - EXACT
 .999999        1              .999999        3.8459E-8      OK 
 2              1.41421        1.41421        .00027788      OK 
 3              1.73205        1.73205        .000308127     OK 
 4              2              2              0              OK  - EXACT
 5              2.23607        2.23607        .000345333     OK 
 9.99999        3.16228        3.16228        .000147321     OK 
 10             3.16228        3.16228        .00000808739   OK 
 40000          200            200            0              OK  - EXACT
 1.23456E+8     11111.1        11111.1        .000468189     OK 
 6.54321E+20    2.55797E+10    2.55797E+10    .000261354     OK 
