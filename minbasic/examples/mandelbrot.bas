10 REM MANDELBROT SET, RENDERED IN ECMA-55 MINIMAL BASIC
20 REM EACH CELL ITERATES Z = Z*Z + C AND IS SHADED BY ESCAPE TIME
30 FOR Y = 0 TO 24
40 FOR X = 0 TO 70
50 LET C = X / 20 - 2.5
60 LET D = 1.2 - Y / 10
70 LET P = 0
80 LET Q = 0
90 LET N = 0
100 LET T = P * P - Q * Q + C
110 LET Q = 2 * P * Q + D
120 LET P = T
130 LET N = N + 1
140 IF P * P + Q * Q > 4 THEN 200
150 IF N < 20 THEN 100
160 PRINT "#";
170 GOTO 320
200 IF N < 3 THEN 240
210 IF N < 6 THEN 250
220 IF N < 10 THEN 260
230 IF N < 14 THEN 270
235 PRINT "*";
237 GOTO 320
240 PRINT " ";
245 GOTO 320
250 PRINT ".";
255 GOTO 320
260 PRINT "-";
265 GOTO 320
270 PRINT "+";
275 GOTO 320
320 NEXT X
330 PRINT
340 NEXT Y
350 END
